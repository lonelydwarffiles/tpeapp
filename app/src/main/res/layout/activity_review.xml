<?xml version="1.0" encoding="utf-8"?>
<!--
  Layout for ReviewActivity.
  A simple vertical form that lets the user enter the partner's session ID
  and start / stop the peer-review screen-sharing stream.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_vertical">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/review_title"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/review_instructions"
        android:textSize="14sp"
        android:layout_marginBottom="24dp" />

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/review_session_id_hint"
        android:layout_marginBottom="24dp"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etSessionId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:maxLines="1"
            android:imeOptions="actionDone" />

    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:id="@+id/tvStreamStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/review_status_ready"
        android:textSize="15sp"
        android:gravity="center"
        android:layout_marginBottom="24dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnStartReview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/review_btn_start"
        android:layout_marginBottom="12dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnStopReview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/review_btn_stop"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

</LinearLayout>
