<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- ================================================================
         Permissions
    ================================================================ -->
    <!-- Required for the foreground FilterService -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <!-- Camera — required by PairingActivity to scan partner QR codes -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature
        android:name="android.hardware.camera"
        android:required="true" />

    <!-- Microphone — required by AdherenceKioskActivity to record the audit video -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- AlarmManager exact alarms — required to schedule daily adherence checks -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />

    <!-- Full-screen intent — required to show AdherenceKioskActivity over lock screen -->
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />

    <!-- FCM / networking -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Device Admin (uninstall lock) -->
    <uses-permission android:name="android.permission.BIND_DEVICE_ADMIN" />

    <!-- Post notifications (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- BLE — scan and connect (Android 12+) -->
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN"
        android:usesPermissionFlags="neverForLocation" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <!-- BLE — legacy support (Android 11 and below) -->
    <uses-permission android:name="android.permission.BLUETOOTH"
        android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN"
        android:maxSdkVersion="30" />
    <uses-feature
        android:name="android.hardware.bluetooth_le"
        android:required="false" />

    <!-- ================================================================
         Application
    ================================================================ -->
    <application
        android:name=".TpeApplication"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Tpeapp">

        <!-- ============================================================
             Adherence Kiosk Activity — full-screen mandatory health check
             Launched by AdherenceAlarmReceiver via full-screen intent.
        ============================================================ -->
        <activity
            android:name=".adherence.AdherenceKioskActivity"
            android:exported="false"
            android:launchMode="singleInstance"
            android:screenOrientation="portrait"
            android:showWhenLocked="true"
            android:turnScreenOn="true" />

        <!-- ============================================================
             Adherence Alarm Receiver — receives AlarmManager broadcasts
             and triggers the kiosk via full-screen notification intent.
        ============================================================ -->
        <receiver
            android:name=".adherence.AdherenceAlarmReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.tpeapp.ACTION_ADHERENCE_ALARM" />
            </intent-filter>
        </receiver>

        <!-- ============================================================
             Pairing Activity — first-launch QR scan to pair with partner
        ============================================================ -->
        <activity
            android:name=".pairing.PairingActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- ============================================================
             Main Activity
        ============================================================ -->
        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:launchMode="singleTop">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ============================================================
             FilterService — foreground, started on boot, bound via AIDL
        ============================================================ -->
        <service
            android:name=".service.FilterService"
            android:exported="true"
            android:foregroundServiceType="dataSync"
            android:permission="com.tpeapp.permission.BIND_FILTER"
            android:stopWithTask="false">
            <intent-filter>
                <action android:name="com.tpeapp.BIND_FILTER_SERVICE" />
            </intent-filter>
        </service>

        <!-- ============================================================
             FCM service
        ============================================================ -->
        <service
            android:name=".fcm.PartnerFcmService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <!-- ============================================================
             Mindful Communication Module — Incoming filter
             Requires the user to grant Notification Access in Settings.
        ============================================================ -->
        <service
            android:name=".mindful.MindfulNotificationService"
            android:exported="false"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>

        <!-- ============================================================
             Mindful Communication Module — Outgoing / tone filter
             Requires the user to grant Accessibility access in Settings.
        ============================================================ -->
        <service
            android:name=".mindful.ToneEnforcementService"
            android:exported="false"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/tone_enforcement_service" />
        </service>

        <!-- ============================================================
             Boot receiver — restart FilterService after reboot
        ============================================================ -->
        <receiver
            android:name=".service.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- ============================================================
             Device Admin receiver
        ============================================================ -->
        <receiver
            android:name=".mdm.AppDeviceAdminReceiver"
            android:exported="true"
            android:permission="android.permission.BIND_DEVICE_ADMIN">
            <meta-data
                android:name="android.app.device_admin"
                android:resource="@xml/device_admin_policies" />
            <intent-filter>
                <action android:name="android.app.action.DEVICE_ADMIN_ENABLED" />
            </intent-filter>
        </receiver>

    </application>

    <!-- Custom permission so only our app (or explicitly granted callers)
         can bind to FilterService. -->
    <permission
        android:name="com.tpeapp.permission.BIND_FILTER"
        android:protectionLevel="signature" />
    <uses-permission android:name="com.tpeapp.permission.BIND_FILTER" />

</manifest>
